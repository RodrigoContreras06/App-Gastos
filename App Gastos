<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Control 50/30/20</title>
    <!-- Tailwind CSS para un diseño moderno y rápido -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons para iconos limpios -->
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-slate-100 font-sans min-h-screen text-slate-800 pb-10">

    <!-- CONTENEDOR PRINCIPAL (Estilo Móvil Centrado) -->
    <div class="max-w-md mx-auto bg-white min-h-screen shadow-xl flex flex-col justify-between">
        
        <!-- CABECERA -->
        <header class="bg-teal-600 text-white p-5 rounded-b-3xl shadow-md text-center">
            <h1 class="text-2xl font-bold tracking-wide flex items-center justify-center gap-2">
                <i data-lucide="wallet"></i> Control 50/30/20
            </h1>
            <p class="text-teal-100 text-sm mt-1">Tu salud financiera al día</p>
        </header>

        <!-- CONTENIDO DE LA APP -->
        <main class="p-5 flex-grow space-y-6">

            <!-- CONFIGURACIÓN DE INGRESOS -->
            <section class="bg-slate-50 p-4 rounded-2xl border border-slate-100 shadow-sm">
                <div class="flex justify-between items-center mb-3">
                    <span class="text-sm text-slate-500 font-semibold uppercase tracking-wider">Ingreso Mensual</span>
                    <button onclick="cambiarIngreso()" class="text-teal-600 hover:text-teal-800 text-xs font-bold flex items-center gap-1">
                        <i data-lucide="edit-2" class="w-3 h-3"></i> Ajustar
                    </button>
                </div>
                <div class="flex justify-between items-end">
                    <span id="txt-ingreso" class="text-2xl font-bold text-slate-900">$3,000,000</span>
                    <div class="text-right">
                        <span class="text-xs text-green-600 font-bold block">Meta Ahorro (20%)</span>
                        <span id="txt-ahorro" class="text-lg font-bold text-green-600">$600,000</span>
                    </div>
                </div>
            </section>

            <!-- DASHBOARD DE BARRAS -->
            <section class="space-y-4">
                <h2 class="text-md font-bold text-slate-700 flex items-center gap-1">
                    <i data-lucide="bar-chart-3" class="w-4 h-4 text-teal-600"></i> Presupuesto del Mes
                </h2>

                <!-- Barra Necesidades -->
                <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <div class="flex justify-between text-sm mb-1.5 font-semibold">
                        <span class="text-blue-700">Necesidades (50% max)</span>
                        <span id="lbl-necesidades" class="text-slate-500">$0 / $1,500,000</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-3.5 overflow-hidden">
                        <div id="bar-necesidades" class="bg-blue-600 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Barra Deseos -->
                <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                    <div class="flex justify-between text-sm mb-1.5 font-semibold">
                        <span class="text-orange-600">Deseos (30% max)</span>
                        <span id="lbl-deseos" class="text-slate-500">$0 / $900,000</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-3.5 overflow-hidden">
                        <div id="bar-deseos" class="bg-orange-500 h-full rounded-full transition-all duration-500" style="width: 0%"></div>
                    </div>
                </div>
            </section>

            <!-- FORMULARIO NUEVO GASTO -->
            <section class="bg-slate-50 p-4 rounded-2xl border border-slate-100">
                <h2 class="text-md font-bold text-slate-700 mb-3 flex items-center gap-1">
                    <i data-lucide="plus-circle" class="w-4 h-4 text-teal-600"></i> Registrar Gasto
                </h2>
                <div class="space-y-3">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Categoría</label>
                        <select id="select-categoria" class="w-full bg-white border border-slate-300 rounded-lg p-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
                            <!-- Necesidades -->
                            <option value="Arriendo" data-grupo="Necesidad">🏠 Arriendo / Vivienda</option>
                            <option value="Transporte" data-grupo="Necesidad" selected>🚌 Transporte / Combustible</option>
                            <option value="Mercado" data-grupo="Necesidad">🛒 Mercado / Alimentos</option>
                            <option value="Servicios" data-grupo="Necesidad">💡 Servicios Públicos</option>
                            <!-- Deseos -->
                            <option value="Diversión" data-grupo="Deseo">🎉 Diversión / Ocio</option>
                            <option value="Comida" data-grupo="Deseo">🍔 Restaurantes / Salidas</option>
                            <option value="Compras" data-grupo="Deseo">🛍️ Ropa / Compras</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Monto ($)</label>
                        <input id="input-monto" type="number" placeholder="Ej. 15000" class="w-full bg-white border border-slate-300 rounded-lg p-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 mb-1">Descripción (Opcional)</label>
                        <input id="input-nota" type="text" placeholder="Ej. Pasajes del día" class="w-full bg-white border border-slate-300 rounded-lg p-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500">
                    </div>
                    <button onclick="agregarGasto()" class="w-full bg-teal-600 hover:bg-teal-700 text-white font-bold py-3 rounded-lg text-sm shadow-md transition-colors flex items-center justify-center gap-2 mt-2">
                        <i data-lucide="check"></i> Guardar Gasto
                    </button>
                </div>
            </section>

            <!-- HISTORIAL -->
            <section class="space-y-3">
                <div class="flex justify-between items-center">
                    <h2 class="text-md font-bold text-slate-700 flex items-center gap-1">
                        <i data-lucide="history" class="w-4 h-4 text-teal-600"></i> Últimos Movimientos
                    </h2>
                    <button onclick="borrarHistorial()" class="text-red-500 hover:text-red-700 text-xs font-semibold flex items-center gap-0.5">
                        <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Reset
                    </button>
                </div>
                <div id="lista-gastos" class="space-y-2">
                    <!-- Los gastos se insertan aquí con JS -->
                </div>
            </section>

        </main>
    </div>

    <!-- MODALES / ALERTAS DINÁMICAS -->
    <div id="modal-alerta" class="fixed inset-0 bg-black/50 hidden flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl p-6 max-w-xs w-full text-center shadow-2xl space-y-4">
            <div class="w-12 h-12 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
            </div>
            <h3 id="modal-titulo" class="text-lg font-bold text-slate-800">Alerta de Límite</h3>
            <p id="modal-mensaje" class="text-slate-600 text-sm">Has alcanzado tu límite de gasto.</p>
            <button onclick="cerrarModal()" class="w-full bg-slate-800 hover:bg-slate-900 text-white py-2.5 rounded-lg text-sm font-semibold transition-colors">
                Entendido
            </button>
        </div>
    </div>

    <!-- LÓGICA JAVASCRIPT -->
    <script>
        // Variables de estado
        let ingresoMensual = parseFloat(localStorage.getItem('ingresoMensual')) || 3000000;
        let gastos = JSON.parse(localStorage.getItem('gastos')) || [];

        const formatoMoneda = new Intl.NumberFormat('es-CO', {
            style: 'currency',
            currency: 'COP',
            minimumFractionDigits: 0
        });

        // Inicializar iconos de Lucide
        lucide.createIcons();

        // Cargar datos al iniciar
        actualizarPantalla();

        function actualizarPantalla() {
            // Calcular Límites
            const limiteNec = ingresoMensual * 0.50;
            const limiteDes = ingresoMensual * 0.30;
            const metaAhorro = ingresoMensual * 0.20;

            // Actualizar Textos
            document.getElementById('txt-ingreso').innerText = formatoMoneda.format(ingresoMensual);
            document.getElementById('txt-ahorro').innerText = formatoMoneda.format(metaAhorro);

            // Calcular Acumulados
            let totalNec = 0;
            let totalDes = 0;

            gastos.forEach(g => {
                if (g.grupo === 'Necesidad') totalNec += g.monto;
                if (g.grupo === 'Deseo') totalDes += g.monto;
            });

            // Actualizar Etiquetas de Barras
            document.getElementById('lbl-necesidades').innerText = `${formatoMoneda.format(totalNec)} / ${formatoMoneda.format(limiteNec)}`;
            document.getElementById('lbl-deseos').innerText = `${formatoMoneda.format(totalDes)} / ${formatoMoneda.format(limiteDes)}`;

            // Calcular porcentajes para las barras
            const pctNec = Math.min((totalNec / limiteNec) * 100, 100);
            const pctDes = Math.min((totalDes / limiteDes) * 100, 100);

            // Renderizar Barras
            const barNec = document.getElementById('bar-necesidades');
            barNec.style.width = `${pctNec}%`;
            barNec.className = `h-full rounded-full transition-all duration-500 ${totalNec >= limiteNec ? 'bg-red-500' : (totalNec >= limiteNec * 0.8 ? 'bg-amber-500' : 'bg-blue-600')}`;

            const barDes = document.getElementById('bar-deseos');
            barDes.style.width = `${pctDes}%`;
            barDes.className = `h-full rounded-full transition-all duration-500 ${totalDes >= limiteDes ? 'bg-red-500' : (totalDes >= limiteDes * 0.8 ? 'bg-amber-500' : 'bg-orange-500')}`;

            // Renderizar Historial
            const lista = document.getElementById('lista-gastos');
            lista.innerHTML = '';

            if (gastos.length === 0) {
                lista.innerHTML = '<p class="text-center text-slate-400 text-xs py-4">No hay gastos registrados este mes.</p>';
                return;
            }

            // Mostrar los últimos 5 gastos
            gastos.slice(-5).reverse().forEach(g => {
                const item = document.createElement('div');
                item.className = "flex items-center justify-between p-3 bg-slate-50 border border-slate-100 rounded-xl";
                
                const esNec = g.grupo === 'Necesidad';
                const iconColor = esNec ? 'text-blue-600 bg-blue-100' : 'text-orange-600 bg-orange-100';
                const iconName = esNec ? 'home' : 'party-popper';

                item.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="p-2 rounded-lg ${iconColor}">
                            <i data-lucide="${iconName}" class="w-4 h-4"></i>
                        </div>
                        <div>
                            <p class="text-sm font-bold text-slate-800">${g.categoria} <span class="font-normal text-slate-500 text-xs">${g.nota ? `(${g.nota})` : ''}</span></p>
                            <p class="text-[10px] text-slate-400">${new Date(g.fecha).toLocaleDateString()}</p>
                        </div>
                    </div>
                    <span class="text-sm font-bold text-slate-800">${formatoMoneda.format(g.monto)}</span>
                `;
                lista.appendChild(item);
            });
            lucide.createIcons();
        }

        function agregarGasto() {
            const inputMonto = document.getElementById('input-monto');
            const inputNota = document.getElementById('input-nota');
            const selectCat = document.getElementById('select-categoria');

            const monto = parseFloat(inputMonto.value);
            const nota = inputNota.value;
            const categoria = selectCat.value;
            const grupo = selectCat.options[selectCat.selectedIndex].getAttribute('data-grupo');

            if (isNaN(monto) || monto <= 0) {
                alert("Por favor escribe un monto válido.");
                return;
            }

            // Calcular acumulados anteriores
            let acumuladoAnterior = 0;
            gastos.forEach(g => {
                if (g.grupo === grupo) acumuladoAnterior += g.monto;
            });

            // Guardar nuevo gasto
            const nuevoGasto = {
                id: Date.now(),
                monto,
                categoria,
                grupo,
                nota,
                fecha: new Date().toISOString()
            };

            gastos.push(nuevoGasto);
            localStorage.setItem('gastos', JSON.stringify(gastos));

            // Limpiar formulario
            inputMonto.value = '';
            inputNota.value = '';

            actualizarPantalla();

            // Evaluar Alertas
            const totalActual = acumuladoAnterior + monto;
            const limite = grupo === 'Necesidad' ? ingresoMensual * 0.50 : ingresoMensual * 0.30;
            const pctAnterior = (acumuladoAnterior / limite) * 100;
            const pctActual = (totalActual / limite) * 100;

            if (pctAnterior < 80 && pctActual >= 80 && pctActual < 100) {
                lanzarAlerta("¡Cuidado (80%)!", `Has superado el 80% de tu presupuesto disponible para ${grupo}s.`);
            } else if (pctAnterior < 100 && pctActual >= 100) {
                lanzarAlerta("¡Límite Alcanzado (100%)!", `Has agotado todo tu presupuesto asignado para ${grupo}s.`);
            }
        }

        function cambiarIngreso() {
            const nuevo = prompt("Introduce tu nuevo ingreso mensual:", ingresoMensual);
            if (nuevo && !isNaN(nuevo) && parseFloat(nuevo) > 0) {
                ingresoMensual = parseFloat(nuevo);
                localStorage.setItem('ingresoMensual', ingresoMensual);
                actualizarPantalla();
            }
        }

        function borrarHistorial() {
            if (confirm("¿Estás seguro de que quieres borrar todos los gastos registrados?")) {
                gastos = [];
                localStorage.removeItem('gastos');
                actualizarPantalla();
            }
        }

        // Modales de alertas
        function lanzarAlerta(titulo, mensaje) {
            document.getElementById('modal-titulo').innerText = titulo;
            document.getElementById('modal-mensaje').innerText = mensaje;
            document.getElementById('modal-alerta').classList.remove('hidden');
        }

        function cerrarModal() {
            document.getElementById('modal-alerta').classList.add('hidden');
        }
    </script>
</body>
</html>
